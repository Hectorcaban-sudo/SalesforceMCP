{
  "GovConRag": {
    "OpenAiApiKey": "sk-your-openai-key",
    "ChatModel": "gpt-4o",
    "EmbeddingModel": "text-embedding-3-small",
    "LiteGraphDbPath": "data/govcon.db",
    "TenantName": "GovConRAG",
    "GraphName": "KnowledgeGraph",
    "SharePoint": {
      "TenantId": "your-azure-tenant-id",
      "ClientId": "your-app-registration-client-id",
      "ClientSecret": "your-client-secret"
    },
    "Mqtt": {
      "BrokerUri": "mqtt://localhost:1883",
      "Username": "",
      "Password": "",
      "UseTls": false
    },
    "Reconciliation": {
      "IntervalMinutes": 60,
      "Sources": [
        {
          "RootRef": "siteId|driveId|root",
          "Source": "SharePoint",
          "Domain": "contracts",
          "TenantId": "default"
        },
        {
          "RootRef": "/data/excel-imports",
          "Source": "Excel",
          "Domain": "accounts",
          "TenantId": "default"
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Wolverine": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/govconrag-.log",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/audit-.jsonl",
          "rollingInterval": "Day",
          "outputTemplate": "{Message:lj}{NewLine}"
        }
      }
    ]
  }
}
