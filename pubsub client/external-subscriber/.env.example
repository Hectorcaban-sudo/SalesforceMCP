# Salesforce Connected App credentials
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret
SF_USERNAME=integration.user@example.com
SF_PASSWORD=password_plus_security_token

# Pub/Sub API endpoint (rarely changes)
PUBSUB_ENDPOINT=api.pubsub.salesforce.com:7443

# Topics
REQUEST_TOPIC=/event/Einstein_Chat_Request__e
RESPONSE_TOPIC=/event/Einstein_Chat_Response__e

# Flow control batch size
BATCH_SIZE=10
