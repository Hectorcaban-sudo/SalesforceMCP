# Copy to .env and fill in values. Never commit .env.

# ── Entra ID ──────────────────────────────────────────────────────────────────
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Global Graph app registration (fallback for all SharePoint libraries) ──────
# Grant: Sites.Read.All, Files.Read.All
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_SECRET=your-global-graph-secret

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AOAI_ENDPOINT=https://your-resource.openai.azure.com/
AOAI_KEY=your-aoai-key

# ── LiteGraph ─────────────────────────────────────────────────────────────────
# No password/encryption needed — the file is on a secured volume.
# DatabasePath is set via LiteGraph__DatabasePath env var in docker-compose.

# ── Bot Framework (Microsoft.Agents SDK) ──────────────────────────────────────
BOT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_CLIENT_SECRET=your-bot-app-secret

# ── Optional: SQL data source credentials ─────────────────────────────────────
# COSTPOINT_CONN_STR="Server=sql01;Database=CPAS;User Id=rag;Password=..."
# DELTEK_TOKEN=Bearer eyJhbGci...
