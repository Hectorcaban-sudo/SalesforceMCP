{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Agents": "Information",
      "SharePointRag": "Debug"
    }
  },
  "AllowedHosts": "*",

  // ═══════════════════════════════════════════════════════════════════════════
  //  AGENT AUTHENTICATION  (Bot Framework / Microsoft.Agents SDK)
  // ═══════════════════════════════════════════════════════════════════════════
  "AgentAuthentication": {
    "ClientId":     "<YOUR-BOT-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-BOT-APP-CLIENT-SECRET>",
    "TenantId":     "<YOUR-TENANT-ID>"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  GLOBAL GRAPH CREDENTIALS
  //  Used by any LibraryDefinition that does NOT specify its own ClientId/Secret.
  //  For tighter security, give each library its own app registration.
  // ═══════════════════════════════════════════════════════════════════════════
  "GlobalGraph": {
    "TenantId":     "<YOUR-TENANT-ID>",
    "ClientId":     "<YOUR-GLOBAL-GRAPH-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-GLOBAL-GRAPH-APP-CLIENT-SECRET>"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  AZURE OPENAI  (shared across all RAG systems)
  // ═══════════════════════════════════════════════════════════════════════════
  "AzureOpenAI": {
    "Endpoint":            "https://<YOUR-AOAI-RESOURCE>.openai.azure.com/",
    "ApiKey":              "<YOUR-AOAI-KEY>",
    "ChatDeployment":      "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large",
    "EmbeddingDimensions": 3072
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  SHARPCOREDB  (one encrypted sub-directory is created per system)
  //
  //  Directory layout after indexing:
  //    /app/data/scdb/
  //      General/              ← GeneralDocs system
  //      PastPerformance/      ← PastPerformance system
  //      HR/                   ← HR system
  // ═══════════════════════════════════════════════════════════════════════════
  "SharpCoreDB": {
    "DataDirectory":       "/app/data/scdb",
    "EncryptionPassword":  "<SET-VIA-ENV-OR-SECRETS>",
    "ChunksTable":         "chunks",
    "EmbeddingsCollection":"chunk_embeddings"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  CHUNKING  (shared across all libraries)
  // ═══════════════════════════════════════════════════════════════════════════
  "Chunking": {
    "MaxTokensPerChunk": 512,
    "OverlapTokens":     64
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  GENERAL AGENT  (standard SharePoint Q&A bot)
  // ═══════════════════════════════════════════════════════════════════════════
  "Agent": {
    "SystemPrompt": "You are an intelligent assistant that answers questions using content retrieved from the company SharePoint document library.\n\nRules:\n- Only answer from the provided context chunks.\n- Always cite the source document (title + URL) for every claim.\n- If the context does not contain enough information, say so clearly.\n- Be concise but complete.",
    "MaxTokens":    1024,
    "Temperature":  0.2
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  WHICH SYSTEMS EACH BOT SEARCHES
  //
  //  SharePointRagAgent   → searches "General" only
  //  PastPerformanceAgent → searches "PastPerformance" + "ProposalArchive"
  //                         (fan-out: results from both are merged + re-ranked)
  // ═══════════════════════════════════════════════════════════════════════════
  "SharePointRagAgent": {
    "SystemNames": [ "General" ]
  },

  "PastPerformanceAgent": {
    "SystemNames": [ "PastPerformance", "ProposalArchive" ]
  },

  // ═══════════════════════════════════════════════════════════════════════════
  //  RAG REGISTRY  — the heart of the multi-library configuration
  //
  //  LIBRARIES  define individual SharePoint site + document library pairs.
  //             Each library gets its own crawler and can have its own
  //             app registration (leave ClientId/Secret empty to use GlobalGraph).
  //
  //  SYSTEMS    define logical RAG indexes. Each system:
  //             - aggregates one or more Libraries
  //             - gets its own isolated SharpCoreDB HNSW index
  //             - exposes TopK and MinScore tuning knobs
  //
  //  A library can appear in multiple systems — it will be independently
  //  indexed into each system's vector store.
  // ═══════════════════════════════════════════════════════════════════════════
  "RagRegistry": {

    "Libraries": [

      // ── Library 1: General corporate documents ──────────────────────────────
      {
        "Name":               "GeneralDocs",
        "SiteUrl":            "https://contoso.sharepoint.com/sites/Corporate",
        "LibraryName":        "Documents",
        "TenantId":           "",
        "ClientId":           "",
        "ClientSecret":       "",
        "AllowedExtensions":  [ ".pdf", ".docx", ".pptx", ".xlsx", ".txt", ".md", ".html" ],
        "MaxFileSizeMb":      50,
        "CrawlParallelism":   4,
        "RootFolderPath":     null
      },

      // ── Library 2: Past performance questionnaires and CPARS reports ────────
      {
        "Name":               "PastPerformanceDocs",
        "SiteUrl":            "https://contoso.sharepoint.com/sites/CaptureTeam",
        "LibraryName":        "PastPerformance",
        "TenantId":           "",
        "ClientId":           "",
        "ClientSecret":       "",
        "AllowedExtensions":  [ ".pdf", ".docx", ".xlsx" ],
        "MaxFileSizeMb":      100,
        "CrawlParallelism":   8,
        "RootFolderPath":     null
      },

      // ── Library 3: Proposal archive (prior submissions)  ────────────────────
      // Note: Uses its OWN dedicated app registration for tighter access control
      {
        "Name":               "ProposalArchiveDocs",
        "SiteUrl":            "https://contoso.sharepoint.com/sites/Proposals",
        "LibraryName":        "SubmittedProposals",
        "TenantId":           "<PROPOSALS-TENANT-ID>",
        "ClientId":           "<PROPOSALS-APP-CLIENT-ID>",
        "ClientSecret":       "<PROPOSALS-APP-CLIENT-SECRET>",
        "AllowedExtensions":  [ ".pdf", ".docx", ".pptx" ],
        "MaxFileSizeMb":      200,
        "CrawlParallelism":   4,
        "RootFolderPath":     "FY2020-Present"
      },

      // ── Library 4: HR policies (exclusive to HR system) ─────────────────────
      {
        "Name":               "HRPolicies",
        "SiteUrl":            "https://contoso.sharepoint.com/sites/HR",
        "LibraryName":        "Policies",
        "TenantId":           "",
        "ClientId":           "",
        "ClientSecret":       "",
        "AllowedExtensions":  [ ".pdf", ".docx", ".html" ],
        "MaxFileSizeMb":      25,
        "CrawlParallelism":   2,
        "RootFolderPath":     null
      }
    ],

    "Systems": [

      // ── System 1: General knowledge base ────────────────────────────────────
      // Used by: SharePointRagAgent
      // Feeds from: GeneralDocs only
      {
        "Name":         "General",
        "Description":  "General corporate knowledge base (policies, procedures, announcements)",
        "LibraryNames": [ "GeneralDocs" ],
        "TopK":         5,
        "MinScore":     0.5
      },

      // ── System 2: Past Performance ───────────────────────────────────────────
      // Used by: PastPerformanceAgent (together with ProposalArchive)
      // Feeds from: PastPerformanceDocs only
      // → Strict CPARS + PPQ content; separate from proposal prose
      {
        "Name":         "PastPerformance",
        "Description":  "CPARS reports, PPQs, and past performance questionnaires",
        "LibraryNames": [ "PastPerformanceDocs" ],
        "TopK":         8,
        "MinScore":     0.45
      },

      // ── System 3: Proposal Archive ───────────────────────────────────────────
      // Used by: PastPerformanceAgent (fan-out with PastPerformance)
      // Feeds from: ProposalArchiveDocs only
      // → Prior proposal volumes; rich narrative content for reuse
      {
        "Name":         "ProposalArchive",
        "Description":  "Submitted proposal past performance volumes (FY2020-present)",
        "LibraryNames": [ "ProposalArchiveDocs" ],
        "TopK":         5,
        "MinScore":     0.4
      },

      // ── System 4: HR ─────────────────────────────────────────────────────────
      // Used by: (future HrAgent or direct REST queries)
      // Feeds from: HRPolicies only
      // → Completely isolated; HR content never leaks into other systems
      {
        "Name":         "HR",
        "Description":  "HR policies, benefits, and employee handbook",
        "LibraryNames": [ "HRPolicies" ],
        "TopK":         4,
        "MinScore":     0.55
      },

      // ── System 5: Full federation example ────────────────────────────────────
      // Queries via REST: POST /api/rag/ask?systems=AllContent
      // Feeds from: ALL libraries → useful for broad executive searches
      {
        "Name":         "AllContent",
        "Description":  "Federated search across all configured libraries",
        "LibraryNames": [ "GeneralDocs", "PastPerformanceDocs", "ProposalArchiveDocs", "HRPolicies" ],
        "TopK":         10,
        "MinScore":     0.4
      }
    ]
  }
}
