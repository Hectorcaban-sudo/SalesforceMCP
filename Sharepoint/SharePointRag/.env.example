# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Entra ID tenant
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SharePoint / Graph app registration
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_SECRET=your-graph-app-secret
SP_SITE_URL=https://contoso.sharepoint.com/sites/MyLibrary

# Azure OpenAI
AOAI_ENDPOINT=https://your-resource.openai.azure.com/
AOAI_KEY=your-aoai-key

# Azure AI Search
SEARCH_ENDPOINT=https://your-resource.search.windows.net
SEARCH_KEY=your-search-admin-key

# Bot Framework app registration (for Microsoft.Agents auth)
BOT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_CLIENT_SECRET=your-bot-app-secret
