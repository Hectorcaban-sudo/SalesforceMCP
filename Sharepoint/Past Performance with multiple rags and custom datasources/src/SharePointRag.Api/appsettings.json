{
  "Logging": {
    "LogLevel": {
      "Default":              "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Agents":     "Information",
      "SharePointRag":        "Debug"
    }
  },
  "AllowedHosts": "*",

  "AgentAuthentication": {
    "ClientId":     "<YOUR-BOT-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-BOT-APP-CLIENT-SECRET>",
    "TenantId":     "<YOUR-TENANT-ID>"
  },

  "GlobalGraph": {
    "TenantId":     "<YOUR-TENANT-ID>",
    "ClientId":     "<YOUR-GLOBAL-GRAPH-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-GLOBAL-GRAPH-APP-CLIENT-SECRET>"
  },

  "AzureOpenAI": {
    "Endpoint":            "https://<YOUR-AOAI-RESOURCE>.openai.azure.com/",
    "ApiKey":              "<YOUR-AOAI-KEY>",
    "ChatDeployment":      "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large",
    "EmbeddingDimensions": 3072
  },

  "SharpCoreDB": {
    "DataDirectory":        "/app/data/scdb",
    "EncryptionPassword":   "<SET-VIA-ENV-OR-SECRETS>",
    "ChunksTable":          "chunks",
    "EmbeddingsCollection": "chunk_embeddings"
  },

  "Chunking": {
    "MaxTokensPerChunk": 512,
    "OverlapTokens":     64
  },

  "Agent": {
    "SystemPrompt": "You are an intelligent assistant that answers questions using content from the organisation's knowledge base.\n\nRules:\n- Only answer from the provided context chunks.\n- Always cite the source (title + URL or data source name) for every claim.\n- If the context does not contain enough information, say so clearly.\n- Be concise but complete.",
    "MaxTokens":    1024,
    "Temperature":  0.2
  },

  "SharePointRagAgent":   { "SystemNames": [ "General" ] },
  "PastPerformanceAgent": { "SystemNames": [ "PastPerformance", "ProposalArchive" ] },

  "RagRegistry": {

    "DataSources": [

      // ── SharePoint connector ──────────────────────────────────────────────
      {
        "Name":             "GeneralDocs",
        "Type":             "SharePoint",
        "CrawlParallelism": 4,
        "DeltaSupported":   true,
        "Properties": {
          "SiteUrl":           "https://contoso.sharepoint.com/sites/Corporate",
          "LibraryName":       "Documents",
          "AllowedExtensions": ".pdf,.docx,.pptx,.xlsx,.txt,.md,.html",
          "MaxFileSizeMb":     "50"
        }
      },

      // ── SharePoint connector (dedicated app registration) ─────────────────
      {
        "Name":             "PastPerformanceDocs",
        "Type":             "SharePoint",
        "CrawlParallelism": 8,
        "DeltaSupported":   true,
        "Properties": {
          "SiteUrl":           "https://contoso.sharepoint.com/sites/CaptureTeam",
          "LibraryName":       "PastPerformance",
          "TenantId":          "<YOUR-TENANT-ID>",
          "ClientId":          "<PP-APP-CLIENT-ID>",
          "ClientSecret":      "<PP-APP-CLIENT-SECRET>",
          "AllowedExtensions": ".pdf,.docx,.xlsx",
          "MaxFileSizeMb":     "100"
        }
      },

      // ── SQL connector (Deltek Costpoint — read contracts table) ───────────
      {
        "Name":             "DeltekCostpointContracts",
        "Type":             "SqlDatabase",
        "CrawlParallelism": 4,
        "DeltaSupported":   true,
        "Properties": {
          "ConnectionString":  "Server=costpoint-db.contoso.com;Database=CPAS;Integrated Security=true;TrustServerCertificate=true",
          "Provider":          "SqlServer",
          "Query":             "SELECT PROJ_ID AS Id, PROJ_ID + ' ' + PROJ_NAME + ' - ' + PROJ_DESC AS Content, PROJ_NAME AS Title, NULL AS Url, LAST_MOD_DATE AS ModifiedAt FROM GV_PROJECTS WHERE PROJ_STATUS = 'A'",
          "IdColumn":          "Id",
          "ContentColumn":     "Content",
          "TitleColumn":       "Title",
          "UrlColumn":         "Url",
          "ModifiedAtColumn":  "ModifiedAt",
          "DeltaFilter":       "LAST_MOD_DATE > @since"
        }
      },

      // ── SQL connector (PostgreSQL — custom BD/CRM database) ───────────────
      {
        "Name":             "CrmOpportunities",
        "Type":             "SqlDatabase",
        "CrawlParallelism": 4,
        "DeltaSupported":   true,
        "Properties": {
          "ConnectionString":  "Host=crm-pg.contoso.com;Database=crm;Username=rag_reader;Password=<SECRET>",
          "Provider":          "Postgres",
          "Query":             "SELECT id::text, opportunity_name || ' ' || description AS content, opportunity_name AS title, crm_url AS url, updated_at AS modified_at FROM opportunities WHERE stage != 'Lost'",
          "IdColumn":          "id",
          "ContentColumn":     "content",
          "TitleColumn":       "title",
          "UrlColumn":         "url",
          "ModifiedAtColumn":  "modified_at"
        }
      },

      // ── Excel connector (contract matrix spreadsheets) ────────────────────
      {
        "Name":             "ContractMatrices",
        "Type":             "Excel",
        "CrawlParallelism": 2,
        "DeltaSupported":   true,
        "Properties": {
          "FilePaths":      "/mnt/shared/contracts/*.xlsx,/mnt/shared/awards/*.xlsx",
          "SheetName":      "Contracts",
          "ContentColumn":  "Description",
          "TitleColumn":    "ContractNumber",
          "UrlColumn":      "SharePointLink"
        }
      },

      // ── Excel connector (CSV employee skills matrix) ──────────────────────
      {
        "Name":             "EmployeeSkills",
        "Type":             "Excel",
        "CrawlParallelism": 1,
        "DeltaSupported":   false,
        "Properties": {
          "FilePaths":     "/mnt/shared/hr/skills-matrix.csv",
          "ContentColumn": "Skills",
          "TitleColumn":   "EmployeeName"
        }
      },

      // ── Deltek Vantagepoint connector ─────────────────────────────────────
      {
        "Name":             "DeltekVantagepoint",
        "Type":             "Deltek",
        "CrawlParallelism": 4,
        "DeltaSupported":   true,
        "Properties": {
          "BaseUrl":  "https://yourfirm.deltekfirst.com/VantagePoint/api/v1",
          "ApiKey":   "Bearer <YOUR-DELTEK-TOKEN>",
          "Entities": "Projects,Clients,Employees",
          "Filter":   "ProjectStatus eq 'Active'",
          "PageSize": "200"
        }
      },

      // ── Custom connector (REST API skeleton) ──────────────────────────────
      {
        "Name":             "InternalKnowledgeBase",
        "Type":             "Custom",
        "CrawlParallelism": 4,
        "DeltaSupported":   false,
        "Properties": {
          "CustomType": "SharePointRag.Core.Connectors.RestApiConnectorExample",
          "BaseUrl":    "https://kb.contoso.internal/api",
          "ApiKey":     "<YOUR-KB-TOKEN>",
          "Endpoint":   "/articles",
          "PageSize":   "100"
        }
      }

    ],

    "Systems": [

      // ── General corporate knowledge base ─────────────────────────────────
      {
        "Name":            "General",
        "Description":     "Corporate knowledge base: SharePoint docs + internal KB",
        "DataSourceNames": [ "GeneralDocs", "InternalKnowledgeBase" ],
        "TopK":            5,
        "MinScore":        0.5
      },

      // ── Past Performance: SharePoint PPQs only ────────────────────────────
      {
        "Name":            "PastPerformance",
        "Description":     "CPARS, PPQs, and past performance questionnaires",
        "DataSourceNames": [ "PastPerformanceDocs" ],
        "TopK":            8,
        "MinScore":        0.45
      },

      // ── Proposal Archive ──────────────────────────────────────────────────
      {
        "Name":            "ProposalArchive",
        "Description":     "Prior submitted proposal past performance volumes",
        "DataSourceNames": [ "PastPerformanceDocs" ],
        "TopK":            5,
        "MinScore":        0.4
      },

      // ── Contracts: SQL + Excel + Deltek ───────────────────────────────────
      {
        "Name":            "Contracts",
        "Description":     "Active contracts from Costpoint DB, Excel matrices, and Deltek Vantagepoint",
        "DataSourceNames": [ "DeltekCostpointContracts", "ContractMatrices", "DeltekVantagepoint" ],
        "TopK":            8,
        "MinScore":        0.45
      },

      // ── BD / CRM Pipeline ─────────────────────────────────────────────────
      {
        "Name":            "BdPipeline",
        "Description":     "Business development: CRM opportunities + Deltek pipeline",
        "DataSourceNames": [ "CrmOpportunities", "DeltekVantagepoint" ],
        "TopK":            6,
        "MinScore":        0.5
      },

      // ── HR ────────────────────────────────────────────────────────────────
      {
        "Name":            "HR",
        "Description":     "Employee skills matrix and HR policies",
        "DataSourceNames": [ "EmployeeSkills" ],
        "TopK":            4,
        "MinScore":        0.55
      },

      // ── Full federation: every configured source ──────────────────────────
      {
        "Name":            "AllContent",
        "Description":     "Federated search across all data sources",
        "DataSourceNames": [
          "GeneralDocs", "PastPerformanceDocs",
          "DeltekCostpointContracts", "CrmOpportunities",
          "ContractMatrices", "EmployeeSkills",
          "DeltekVantagepoint", "InternalKnowledgeBase"
        ],
        "TopK":            12,
        "MinScore":        0.35
      }
    ]
  }
}
