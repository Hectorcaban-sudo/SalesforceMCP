# Copy to .env and fill in values. Never commit .env.

# ── Entra ID ──────────────────────────────────────────────────────────────────
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Global Graph app registration (fallback for all libraries) ─────────────────
# Grant: Sites.Read.All, Files.Read.All
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SP_CLIENT_SECRET=your-global-graph-secret

# ── Per-library app registrations (optional; override GlobalGraph per library) ──
# Uncomment and set in appsettings or docker-compose if you want tighter access
# PP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PP_CLIENT_SECRET=your-pp-secret
# PROPOSALS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROPOSALS_CLIENT_SECRET=your-proposals-secret

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AOAI_ENDPOINT=https://your-resource.openai.azure.com/
AOAI_KEY=your-aoai-key

# ── SharpCoreDB encryption ────────────────────────────────────────────────────
# AES-256-GCM password for all encrypted .scdb files.
# Use a long random string. Treat like a database master password.
SCDB_PASSWORD=use-a-long-random-string-here-min-32-chars

# ── Bot Framework (Microsoft.Agents SDK) ──────────────────────────────────────
BOT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_CLIENT_SECRET=your-bot-app-secret
