{
  "Logging": {
    "LogLevel": {
      "Default":              "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Agents":     "Information",
      "SharePointRag":        "Debug"
    }
  },
  "AllowedHosts": "*",

  "AgentAuthentication": {
    "ClientId":     "<YOUR-BOT-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-BOT-APP-CLIENT-SECRET>",
    "TenantId":     "<YOUR-TENANT-ID>"
  },

  "GlobalGraph": {
    "TenantId":     "<YOUR-TENANT-ID>",
    "ClientId":     "<YOUR-GLOBAL-GRAPH-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-GLOBAL-GRAPH-APP-CLIENT-SECRET>"
  },

  "AzureOpenAI": {
    "Endpoint":            "https://<YOUR-AOAI-RESOURCE>.openai.azure.com/",
    "ApiKey":              "<YOUR-AOAI-KEY>",
    "ChatDeployment":      "gpt-4o",
    "EmbeddingDeployment": "text-embedding-3-large",
    "EmbeddingDimensions": 3072
  },

  "SharpCoreDB": {
    "DataDirectory":        "/app/data/scdb",
    "EncryptionPassword":   "<SET-VIA-ENV-OR-SECRETS>",
    "ChunksTable":          "chunks",
    "EmbeddingsCollection": "chunk_embeddings"
  },

  "Chunking": {
    "MaxTokensPerChunk": 512,
    "OverlapTokens":     64
  },

  "Agent": {
    "SystemPrompt": "You are an intelligent assistant that answers questions using content from the organisation's knowledge base.\n\nRules:\n- Only answer from the provided context chunks.\n- Always cite the source (title + URL or data source name) for every claim.\n- If the context does not contain enough information, say so clearly.\n- Be concise but complete.",
    "MaxTokens":    1024,
    "Temperature":  0.2
  },

  // ── Which RAG systems each bot searches ────────────────────────────────────
  // System names must match RagRegistry.Systems[*].Name below.
  "SharePointRagAgent":   { "SystemNames": [ "General" ] },

  // The PP agent fans out across BOTH PastPerformance AND Contracts systems,
  // so it searches SharePoint PPQs, Deltek projects, SQL contract DB, and Excel
  // matrices — all in one query.
  "PastPerformanceAgent": { "SystemNames": [ "PastPerformance", "Contracts" ] },

  // ── RagRegistry ────────────────────────────────────────────────────────────
  "RagRegistry": {

    "DataSources": [

      // ── 1. SharePoint: Corporate documents (for General agent) ─────────────
      {
        "Name": "GeneralDocs", "Type": "SharePoint",
        "CrawlParallelism": 4, "DeltaSupported": true,
        "Properties": {
          "SiteUrl":           "https://contoso.sharepoint.com/sites/Corporate",
          "LibraryName":       "Documents",
          "AllowedExtensions": ".pdf,.docx,.pptx,.xlsx,.txt,.md,.html",
          "MaxFileSizeMb":     "50"
        }
      },

      // ── 2. SharePoint: Past performance questionnaires + CPARS reports ─────
      {
        "Name": "PastPerformanceDocs", "Type": "SharePoint",
        "CrawlParallelism": 8, "DeltaSupported": true,
        "Properties": {
          "SiteUrl":           "https://contoso.sharepoint.com/sites/CaptureTeam",
          "LibraryName":       "PastPerformance",
          "ClientId":          "<PP-APP-CLIENT-ID>",
          "ClientSecret":      "<PP-APP-CLIENT-SECRET>",
          "AllowedExtensions": ".pdf,.docx,.xlsx",
          "MaxFileSizeMb":     "100"
        }
      },

      // ── 3. SQL: Deltek Costpoint — active contracts from the database ───────
      // ContractExtractor will direct-map columns to ContractRecord fields.
      // PROJ_ID → ContractNumber, PROJ_NAME → Title, PROJ_DESC → Description, etc.
      {
        "Name": "DeltekCostpointDB", "Type": "SqlDatabase",
        "CrawlParallelism": 4, "DeltaSupported": true,
        "Properties": {
          "ConnectionString":  "Server=costpoint.contoso.com;Database=CPAS;Integrated Security=true;TrustServerCertificate=true",
          "Provider":          "SqlServer",
          "Query":             "SELECT PROJ_ID AS Id, PROJ_ID + ' ' + PROJ_NAME + '. ' + ISNULL(PROJ_DESC,'') AS Content, PROJ_NAME AS Title, NULL AS Url, LAST_MOD_DATE AS ModifiedAt, CLIENT_ID AS ClientName, NAICS_CODE AS NAICSCode, CONTRACT_TYPE AS ContractType, CONTRACT_AMT AS ContractAmount, START_DATE AS StartDate, END_DATE AS EndDate, PROJ_STATUS AS ProjectStatus, CO_NAME AS ContractingOfficer, CO_EMAIL AS COEmail FROM GV_PROJECTS WHERE PROJ_STATUS IN ('A','C')",
          "IdColumn":          "Id",
          "ContentColumn":     "Content",
          "TitleColumn":       "Title",
          "UrlColumn":         "Url",
          "ModifiedAtColumn":  "ModifiedAt",
          "DeltaFilter":       "LAST_MOD_DATE > @since"
        }
      },

      // ── 4. Deltek Vantagepoint: Projects + Clients via REST API ────────────
      // ContractExtractor maps Deltek fields: ProjectNumber, ClientName, Budget, etc.
      {
        "Name": "DeltekVantagepoint", "Type": "Deltek",
        "CrawlParallelism": 4, "DeltaSupported": true,
        "Properties": {
          "BaseUrl":  "https://yourfirm.deltekfirst.com/VantagePoint/api/v1",
          "ApiKey":   "Bearer <YOUR-DELTEK-TOKEN>",
          "Entities": "Projects,Clients",
          "Filter":   "ProjectStatus eq 'Active' or ProjectStatus eq 'Completed'",
          "PageSize": "200"
        }
      },

      // ── 5. Excel: Contract award matrices (spreadsheets on file share) ──────
      // Column headers become Metadata keys for direct mapping:
      // ContractNumber, Description, Agency, NAICSCode, ContractAmount, CO, COEmail
      {
        "Name": "ContractMatrices", "Type": "Excel",
        "CrawlParallelism": 2, "DeltaSupported": true,
        "Properties": {
          "FilePaths":     "/mnt/shared/contracts/award-matrices/*.xlsx",
          "SheetName":     "Contracts",
          "ContentColumn": "Description",
          "TitleColumn":   "ContractNumber"
        }
      },

      // ── 6. Excel: CPARS export spreadsheet ────────────────────────────────
      {
        "Name": "CPARSExport", "Type": "Excel",
        "CrawlParallelism": 1, "DeltaSupported": false,
        "Properties": {
          "FilePaths":     "/mnt/shared/cpars/cpars-export.xlsx",
          "ContentColumn": "NarrativeText",
          "TitleColumn":   "ContractNumber"
        }
      }

    ],

    "Systems": [

      // ── General knowledge base (SharePoint corporate docs) ─────────────────
      {
        "Name":            "General",
        "Description":     "General corporate knowledge base",
        "DataSourceNames": [ "GeneralDocs" ],
        "TopK":            5,
        "MinScore":        0.5
      },

      // ── Past Performance: SharePoint narrative documents ───────────────────
      // Feeds PPQs, CPARS printouts, and prior proposal volumes.
      // ContractExtractor uses LLM to extract structured data from free-text.
      {
        "Name":            "PastPerformance",
        "Description":     "CPARS reports, PPQs, and past performance questionnaires (SharePoint)",
        "DataSourceNames": [ "PastPerformanceDocs" ],
        "TopK":            8,
        "MinScore":        0.45
      },

      // ── Contracts: all structured sources ─────────────────────────────────
      // Feeds SQL DB, Deltek API, Excel matrices, and CPARS export.
      // ContractExtractor direct-maps structured fields → no LLM extraction cost.
      // PP agent searches BOTH PastPerformance + Contracts simultaneously.
      {
        "Name":            "Contracts",
        "Description":     "Active contracts from Costpoint DB, Deltek Vantagepoint, Excel matrices, and CPARS export",
        "DataSourceNames": [ "DeltekCostpointDB", "DeltekVantagepoint", "ContractMatrices", "CPARSExport" ],
        "TopK":            10,
        "MinScore":        0.4
      },

      // ── Full federation (REST only) ────────────────────────────────────────
      {
        "Name":            "AllContent",
        "Description":     "Federated search across all configured data sources",
        "DataSourceNames": [ "GeneralDocs", "PastPerformanceDocs", "DeltekCostpointDB", "DeltekVantagepoint", "ContractMatrices", "CPARSExport" ],
        "TopK":            12,
        "MinScore":        0.35
      }

    ]
  }
}
