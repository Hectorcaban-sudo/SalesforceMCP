{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "SharePointRag": "Debug"
    }
  },

  "SharePoint": {
    "SiteUrl": "https://contoso.sharepoint.com/sites/MyLibrary",
    "LibraryName": "Documents",
    "TenantId": "<YOUR-TENANT-ID>",
    "ClientId": "<YOUR-GRAPH-APP-CLIENT-ID>",
    "ClientSecret": "<YOUR-GRAPH-APP-CLIENT-SECRET>",
    "AllowedExtensions": [ ".pdf", ".docx", ".pptx", ".xlsx", ".txt", ".md", ".html" ],
    "MaxFileSizeMb": 50,
    "CrawlParallelism": 8
  },

  "AzureOpenAI": {
    "Endpoint": "https://<YOUR-AOAI-RESOURCE>.openai.azure.com/",
    "ApiKey": "<YOUR-AOAI-KEY>",
    "EmbeddingDeployment": "text-embedding-3-large",
    "EmbeddingDimensions": 3072
  },

  "SharpCoreDB": {
    "DataDirectory": "/app/data/scdb",
    "EncryptionPassword": "<SET-VIA-ENV-OR-SECRETS>",
    "ChunksTable": "chunks",
    "EmbeddingsCollection": "chunk_embeddings",
    "TopK": 5,
    "MinScore": 0.5
  },

  "Chunking": {
    "MaxTokensPerChunk": 512,
    "OverlapTokens": 64
  },

  "Indexer": {
    "DeltaIntervalMinutes": 30,
    "FullIndexIntervalHours": 24
  }
}
