# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Path to the compiled MCP server executable
# After dotnet publish, this will be at SalesforceMcpServer/publish/SalesforceMcpServer
MCP_SERVER_PATH=../SalesforceMcpServer/publish/SalesforceMcpServer

# Optional: Override model (default: claude-sonnet-4-20250514)
# MODEL_NAME=claude-opus-4-20250514
