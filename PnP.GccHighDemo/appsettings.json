{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PnPCore": {
    "DisableTelemetry": "false",
    "Environment": "USGovernmentHigh",
    "PnPContext": {
      "GraphFirst": "true",
      "GraphCanUseBeta": "true",
      "GraphAlwaysUseBeta": "false"
    },
    "HttpRequests": {
      "UserAgent": "ISV|YourCompany|PnPGccHighDemo",
      "Timeout": "100"
    },
    "Credentials": {
      "DefaultConfiguration": "CertificateAuth",
      "Configurations": {
        "CertificateAuth": {
          "ClientId": "{YourClientId}",
          "TenantId": "{YourTenantId}",
          "X509Certificate": {
            "StoreName": "My",
            "StoreLocation": "CurrentUser",
            "Thumbprint": "{YourCertificateThumbprint}"
          }
        }
      }
    },
    "Sites": {
      "TargetSite": {
        "SiteUrl": "https://{your-tenant}.sharepoint.us/sites/{site-name}",
        "AuthenticationProviderName": "CertificateAuth"
      }
    }
  }
}