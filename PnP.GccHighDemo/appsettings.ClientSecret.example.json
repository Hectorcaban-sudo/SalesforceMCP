{
  "$note": "EXAMPLE CONFIGURATION - DO NOT USE IN PRODUCTION WITHOUT CERTIFICATE",
  "$warning": "ClientSecret authentication only works for Microsoft Graph APIs, NOT SharePoint REST APIs",
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "PnPCore": {
    "DisableTelemetry": "false",
    "Environment": "USGovernmentHigh",
    "PnPContext": {
      "GraphFirst": "true",
      "GraphCanUseBeta": "true",
      "GraphAlwaysUseBeta": "false"
    },
    "HttpRequests": {
      "UserAgent": "ISV|YourCompany|PnPGccHighDemo",
      "Timeout": "100"
    },
    "Sites": {
      "TargetSite": {
        "SiteUrl": "https://{your-tenant}.sharepoint.us/sites/{site-name}"
      }
    }
  },
  
  "Authentication": {
    "ClientId": "{YourClientId}",
    "ClientSecret": "{YourClientSecret}",
    "TenantId": "{YourTenantId}"
  }
}